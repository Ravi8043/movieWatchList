// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // relations
  watchlist      Watchlist[]        // user can have many watchlist items
  createdMovies  Movie[] @relation("Creator") // user can create many movies
}

model Movie {
  id        Int      @id @default(autoincrement())
  title     String
  year      Int
  rating    Float
  overview  String?
  
  userId    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  creator   User       @relation("Creator", fields: [userId], references: [id], onDelete: Cascade)
  watchlist Watchlist[]
}

model Watchlist {
  id        Int      @id @default(autoincrement())

  userId    Int
  movieId   Int
  status    WatchListStatus @default(PLANNED)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  user      User     @relation(fields: [userId], references: [id])
  movie     Movie    @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])
}

enum WatchListStatus {
  PLANNED
  WATCHED
  NOT_INTERESTED
}